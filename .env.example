# LLM Provider Configuration
# Options: gemini (default, free), claude (highest quality), groq (fastest)
LLM_PROVIDER=gemini
LLM_API_KEY=your_api_key_here

# Vercel Postgres (auto-injected by Vercel, set manually for local dev)
POSTGRES_URL=postgres://user:password@host/db?sslmode=require
POSTGRES_PRISMA_URL=postgres://user:password@host/db?pgbouncer=true&sslmode=require
POSTGRES_URL_NO_SSL=postgres://user:password@host/db
POSTGRES_URL_NON_POOLING=postgres://user:password@host/db?sslmode=require
POSTGRES_USER=your_user
POSTGRES_HOST=your_host
POSTGRES_PASSWORD=your_password
POSTGRES_DATABASE=verceldb

# AI Agent bearer token (generate any random string)
ONEVIEW_API_KEY=generate_a_random_32_char_string_here
